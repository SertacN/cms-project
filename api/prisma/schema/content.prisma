enum ContentStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

model Content{
    id Int @default(autoincrement()) @id
    title String @unique
    summary String?
    content String?
    sefUrl String @unique
    orderBy Int @default(0)
    status ContentStatus @default(DRAFT)

    categoryId Int
    category ContentCategory @relation(fields: [categoryId], references: [id])

    files ContentFile[]
    parameters ContentParameterValue[]

    isActive Boolean @default(true)
    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt
    deletedAt DateTime?
    isDeleted Boolean @default(false)
    @@index([isDeleted, isActive])
    @@index([status])
}
