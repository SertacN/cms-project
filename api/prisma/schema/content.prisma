model Content{
    id Int @default(autoincrement()) @id
    title String @unique
    summary String?
    content String?
    sefUrl String @unique
    order Int @default(0)
    categoryId Int
    category Category @relation(fields: [categoryId], references: [id])
    files File[]
    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt
    deletedAt DateTime?
    isDeleted Boolean @default(false)
}