model ContentCategory{
    id Int @default(autoincrement()) @id
    title String @unique
    sefUrl String @unique
    orderBy Int @default(0)
    isActive Boolean @default(true)

    // Parent-Child hiyerarşisi — maksimum 2 seviye (backend'de validate edilir)
    parentId Int?
    parent   ContentCategory?  @relation("CategoryParent", fields: [parentId], references: [id])
    children ContentCategory[] @relation("CategoryParent")

    content Content[]
    parameterDefinitions ContentParameterDefinition[]

    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt
    deletedAt DateTime?
    isDeleted Boolean @default(false)

    @@index([isDeleted])
    @@index([parentId])
}
