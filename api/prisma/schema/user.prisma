enum Role {
  ADMIN
  USER
}

model User{
  id String @default(uuid()) @id
  email String @unique
  password String
  firstName String?
  lastName String?
  role Role @default(USER)
  isActive Boolean @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  refreshToken String?
  deletedAt DateTime?
  isDeleted Boolean @default(false)
  @@index([isDeleted, isActive])
}