enum ParameterType {
  TEXT
  NUMBER
  SELECT
  CHECKBOX
  DATE
  TEXTAREA
}

model ContentParameterDefinition{
    id Int @id @default(autoincrement())
    name String
    label String
    type ParameterType
    options Json?
    isRequired Boolean @default(false)
    orderBy Int @default(0)

    categoryId Int
    category ContentCategory @relation(fields: [categoryId], references: [id], onDelete: Cascade)
    
    values ContentParameterValue[]

    @@index([categoryId])
    @@unique([categoryId, name])
}