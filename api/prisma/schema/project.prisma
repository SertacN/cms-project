model Project{
  id Int @default(autoincrement()) @id
  title String
  summary String?
  content String?
  slug String @unique
  tech String?
  version String?
  imageUrl String?
  techLogoImageUrl String[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  deletedAt DateTime?
  isDeleted Boolean @default(false)
}