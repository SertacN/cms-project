# --------------------
# 1. Genel Ayarlar (Ortak)
# --------------------

# Node bağımlılıkları ve modülleri
# Hem api hem de client içinde bu klasörler olabilir.
node_modules

# Ortak Build (Derleme) ve Log dosyaları
# Çalışma zamanında oluşan dosyalar
/dist
/build
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.eslintcache

# --------------------
# 2. NestJS (API Klasörü)
# --------------------

# NestJS proje klasörü (örneğin: /api)
# Eğer NestJS projeniz ana klasörde değil de bir alt klasördeyse
# bu yolları o klasöre göre ayarlayabilirsiniz (örn. /api/dist)

# TypeScript derleme çıktıları
# (Genellikle NestJS varsayılanı)
/api/dist
/api/*.js

# IDE ve İşletim Sistemi dosyaları
.idea
.vscode
*.sublime-project
*.sublime-workspace
.DS_Store
REVIEW.md
# Test Raporları
/coverage

# --------------------
# 3. Angular (Client Klasörü)
# --------------------

# Angular proje klasörü (örneğin: /client)
# TypeScript derleme çıktıları
/client/dist
/client/out-tsc

# Kütüphane önbellekleri
/client/.angular/cache

# Diğer Angular/Webpack dosyaları
.sass-cache/

# Cypress (varsa)
/cypress/videos
/cypress/screenshots